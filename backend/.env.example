APP_NAME="Turan Asia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

# Поддерживаемые языки сайта (мультиязычность)
SUPPORTED_LOCALES=ru,kz,en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- PostgreSQL ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=turanasia
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# Фронтенд (для CORS и Sanctum)
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1
SESSION_DOMAIN=localhost

# --- Почта (уведомления о заявках) ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@turan-asia.kz"
MAIL_FROM_NAME="${APP_NAME}"

# Менеджер, которому приходят новые заявки
MANAGER_EMAIL=info@turan-asia.kz

# --- Опционально: Telegram-уведомления о заявках (на будущее) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Аналитика (подключаем мы) ---
GA4_MEASUREMENT_ID=
GTM_CONTAINER_ID=
META_PIXEL_ID=

# --- Интеграции (этап 2, пока выключены) ---
# RateHawk — бронирование отелей
RATEHAWK_KEY_ID=
RATEHAWK_API_KEY=

# Эквайринг/оплата — провайдер подбирается с заказчиком
PAYMENT_PROVIDER=
PAYMENT_MERCHANT_ID=
PAYMENT_SECRET=
